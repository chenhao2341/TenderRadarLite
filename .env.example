# Local-only users can leave all Feishu fields empty.
# Replace placeholders in your local .env only. Do not commit real values.

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_URL=
FEISHU_WEBHOOK_URL=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_BOT_MODE=webhook
FEISHU_CHAT_ID=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
AI_ANALYSIS_TIMEOUT_SECONDS=30
# Optional guardrail for local HTML AI analysis. Default is 5 and single-run hard cap is 10.
AI_ANALYSIS_MAX_ITEMS=5
